%include% <emex64.e64h>

section .data
    msg db "hello\r\n\0"

_start:
    mov r0, msg
.loop:
    ldb r1, r0
.retry:
    ldd r2, UART_STATUS
    and r2, UART_STATUS_TX_EMPTY
    bz r2, .retry
    std UART_DATA, r1
    inc r0
    bnz r1, .loop
.end:
    stb PLATFORM_PWR, 0
