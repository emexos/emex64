%define% PLATFORM_PWR   0x1FE00500
%define% FB_ENABLED     0x1FE00700

%define% PT_PAGE_SIZE   0x2000

%define% PT_PRESENT     0b00000001
%define% PT_USER        0b00000010
%define% PT_DIRTY       0b00000100
%define% PT_READ        0b00001000
%define% PT_WRITE       0b00010000
%define% PT_EXEC        0b00100000

%define% PT_KRWX        0b00111001

section .data
    exception_msg db "[!] panic because of exception code: 0x\0"
    hello_msg db "hello world!\r\n\0"
    gui_hello_msg db "hello from emexOS on emex64\r\n\0 ABCDEFGHIJKLMNOPQRSTUVWXYZ \r\n\0 abcdefghijklmnopqrstuvwxyz \r\n\0 01234567890 \r\n\0 @#%^&*()!<>?:;\r\n\0"
    ; ik that it runs out of line lol

; exception handler
_exception_handler:
    bl _puts, exception_msg
    bl _putbase, cr2, 16
    bl _putc, '\n'

    ; no iret needed, platform is panicking
    stb PLATFORM_PWR, 0

    ; some experiments that work:
    ; you can keep running with this code:
    ;
    ; clr cr2
    ; iret

;
; r0: address
; rr: page down aligned
;
_pt_align_addr_down:
    ; ((r0) & ~((PT_PAGE_SIZE) - 1))
    and rr, r0, 0xFFFFE000 ; FRIDA, WE NEED STATIC COMPILER EXPRESSIONS?!?!?
    ret


;
; r0: page table address
; r1: index
;
; rr: page table entry
;
_pt_entry_lookup:
    ; align address down to page size
    bl _pt_align_addr_down, r0
    mov r0, rr

    ; expand index to address (like a cast in C for arrays)
    mul r1, 8
    add r0, r1 ; pointer arithmetic

    ; load page table entry quad word
    ldq rr, r0
    ret

;
; r0: page table pte (same value as valid in CRPTB)
; r1: physical page start
; r2: virtual page start
; r3: flags
;
; rr: if it's not null then it's a page address for the root page
;
; description: automatically allocates pages
;              zeros them out and sets them
;              up with the givven permitives.
;
; note: in case there is no page table entry
;       passed as the main pte it will create
;       one for you and return in rr.
;
_pt_map:
    ; first get down to the page address
    clr r4, r5, r6, r7
    shr r4, r1, 43  ; pgd index
    and r4, 0x3FF
    shr r5, r1, 33  ; pud index
    and r5, 0x3FF
    shr r6, r1, 23  ; pmd index
    and r6, 0x3FF
    shr r7, r1, 13  ; pte index
    and r7, 0x3FF

    bl _kcalloc, 4, 8

    ; checking weither root page table is present
    and r8, r0, PT_PRESENT
    cmp r4, PT_PRESENT
    shl r4, r0, 13
    bne .skip_creating_root_table

    ; creating root page table
    bl _pmm_alloc_zero
    mov r9, rr  ; just move that shi

.skip_creating_root_table:
    ;push r4
    ; now it shall be created and the pgd table sits in r4
    ;shr r1, 
    ;bl _pt_entry_lookup, r4, 
    ;pop rr
    ret

_pt_unmap:
    ret

_pt_destroy:
    ret

;
; r0: table
; r1: idx
; r2: pnf
;
_mmu_table_add_krwx_pnf:
    ; making valid PTE out of pnf
    shl r3, r2, 8
    or r3, PT_KRWX

    ; compute address
    mul r1, 8
    add r1, r0

    ; add to table
    stq r1, r3
    ret

;
; r0: table
; r1: idx
; r2: addr
;
_mmu_table_add_krwx_addr:
    div r2, PT_PAGE_SIZE
    b _mmu_table_add_krwx_pnf

; poc entry
_poc_main:
    ; add UART device to page table first:
    ;
    ; bl _putc, '\n'
    ;
    ret

; kernel entry
_main:
    bl _interrupt_register_handler IRQ_EXCEPTION, _exception_handler

    ; l1 page table setup
    ; we need to first allocate the page
    ; the address of its start lands inside
    ; of rr(return register), to make sure
    ; there are no ghost page tables registered
    ; we gotta have to set all addresses to
    ; zero.
    bl _pmm_alloc_zero
    mov r0, rr

    ; registering 1st page as rw
    clr r1
.loop:
    bl _mmu_table_add_krwx_pnf, r0, r1, r1
    inc r1
    cmp r1, 50
    blt .loop

    ; l2 page table
    bl _pmm_alloc_zero
    mov r1, rr
    bl _mmu_table_add_krwx_addr, r1, 0x0, r0

    ; l3 page table
    bl _pmm_alloc_zero
    mov r2, rr
    bl _mmu_table_add_krwx_addr, r2, 0x0, r1

    ; l4 page table
    bl _pmm_alloc_zero
    mov r3, rr
    bl _mmu_table_add_krwx_addr, r3, 0x0, r2

    ; allocating Stack Memory Page
    bl _pmm_alloc
    mov r10, sp
    add rr, 0x1FFE
    mov sp, rr

    ; registering basetable cr2
    shr r4, r3, 13
    shl r5, r4, 8
    or r5, PT_PRESENT

    ;shr r6, r5, 8
    ;and r6, r5, PT_PRESENT
    ;shr r6, 8
    ;mov r7, PT_PRESENT
    ;bl _putbase, r5, 2
    ;bl _putc, ' '
    ;bl _putbase, r6, 2
    ;bl _putc, ' '
    ;bl _putbase, r7, 2
    ;bl _putc, '\n'
    
    mov cr4, r5

    ; run PoC
    bl _poc_main

    ; restore kernel environment
    clr cr4
    mov sp, r10

    ; say hello
    bl _puts, hello_msg

; TODO:
; screen system
    stb FB_ENABLED, 1
    bl _draw_string, gui_hello_msg, 20, 20, 255

.gui_loop:
    hlt
    b .gui_loop

; main setup routine
_start:
    bl _pmm_init                                    ; initilizing page allocator
    bl _slab_init                                   ; initilizing slab allocator
    bl _interrupt_init                              ; initilizing interrupt controller
    bl _main                                        ; branching to main symbol
    stb PLATFORM_PWR, 0                             ; telling platform device to turn off
