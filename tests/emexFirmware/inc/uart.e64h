%define% UART_BASE      0x0040000000000300
%define% UART_DATA      0x0040000000000300
%define% UART_STATUS    0x0040000000000304
%define% UART_CONTROL   0x0040000000000308

%define% UART_STATUS_RX_READY    0x01
%define% UART_STATUS_TX_EMPTY    0x02
%define% UART_STATUS_RX_FULL     0x04
%define% UART_STATUS_OVERFLOW    0x08

%define% UART_CTRL_RX_IRQ_EN     0x01
%define% UART_CTRL_TX_IRQ_EN     0x02
%define% UART_CTRL_RESET         0x04
