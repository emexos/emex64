%define% INTC_BASE          0x0040000000000000
%define% INTC_REG_PENDING   0x0040000000000000
%define% INTC_REG_ENABLED   0x0040000000000008
%define% INTC_REG_CTRL      0x0040000000000010
%define% INTC_REG_VECTOR    0x0040000000000018
%define% INTC_REG_ACK       0x0040000000000020
%define% INTC_REG_CURRENT   0x0040000000000028

%define% INTC_CTRL_ENABLE   0x1
%define% INTC_CTRL_NESTING  0x2

%define% IRQ_EXCEPTION  0
%define% IRQ_TIMER      1
%define% IRQ_UART       2
%define% IRQ_DISK       3
%define% IRQ_NETWORK    4
%define% IRQ_SOFTWARE   5
%define% IRQ_8042       6   ; spicy x3 silly keyboard controller
