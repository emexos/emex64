%define% RTC_BASE       0x0040000000000200
%define% RTC_SECONDS    0x0040000000000200
%define% RTC_MINUTES    0x0040000000000204
%define% RTC_HOURS      0x0040000000000208
%define% RTC_DAY        0x004000000000020C
%define% RTC_MONTH      0x0040000000000210
%define% RTC_YEAR       0x0040000000000214
%define% RTC_WEEKDAY    0x0040000000000218
