%define% FB_ENABLED 0x1FE00700

%define% FB_FRAMEBUFFER 0x1FE00A01

%define% FB_HEIGHT 512
%define% FB_WIDTH 512

section .data
    gui_line dw 0
    gui_column dw 0

;_draw_rectangle:
;    ret

;
; r0: character
;
_putc:
    bz r0, .end

    ldw r1, gui_column
    ldw r2, gui_line
    
    mov r4, r1
    mov r5, r2
    
    inc r4
    
    mul r1, 8
    mul r2, 10
    
    cmp r0, '\n'
    be .newline

    stw gui_column, r4
    stw gui_line, r5

    mov r3, 511
    
    cmp r0, 127
    bgt .end

    mov r4, _font_data
    mul r5, r0, 8
    add r4, r5

    clr r5
.row_loop:
    add r7, r4, r5
    ldb r6, r7

    clr r8

.col_loop:
    mov r9, 7
    sub r9, r8
    shr r10, r6, r9

    and r10, 1
    bz r10, .skip_pixel

    add r11, r2, r5
    cmp r11, 0

    blt .skip_pixel

    cmp r11, FB_HEIGHT
    bge .skip_pixel

    add r12, r1, r8
    cmp r12, 0

    blt .skip_pixel
    cmp r12, FB_WIDTH
    bge .skip_pixel


    shl r11, 9
    add r11, r12
    add r11, FB_FRAMEBUFFER
    stb r11, r3

.skip_pixel:
    inc r8
    cmp r8, 8
    blt .col_loop

    inc r5
    cmp r5, 8
    blt .row_loop

.end:
    ret

.newline:
    inc r5
    clr r4

    stw gui_column, 0
    stw gui_line, r5

    ret

