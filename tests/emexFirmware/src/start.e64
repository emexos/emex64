%define% PLATFORM_PWR   0x1FE00500
%define% FB_ENABLED     0x1FE00700

section .data
    fw_font_test_msg db "[fw] firmware font test\n     ABCDEFGHIJKLMNOPQRSTUVWXYZ\n     abcdefghijklmnopqrstuvwxyz\n     0123456789\n     @#%^&*()!<>?:;\n\0"
    fw_display_msg db "[fw] display resolution: \0"
    fw_display_x_msg db " x \0"
    fw_display_unavailable db "not installed\n\0"
    fw_memory_msg db "[fw] total memory size: \0"
    fw_memory_available_msg db "[fw] memory available: \0"
    fw_bytes_msg db " Bytes\n\0"
    fw_panic_msg db "[fw] causing panic by division through zero\n\0"

_fw_start:
    bl _interrupt_register_handler IRQ_EXCEPTION, _exception_handler

    bl _puts, fw_font_test_msg

    bl _puts, fw_display_msg
    ldw r0, FB_HEIGHT
    ldw r1, FB_WIDTH
    bz r0, .dsp_not_installed
    bl _putbase, r0, 10
    bl _puts, fw_display_x_msg
    bl _putbase, r1, 10
    bl _putc, '\n'
    b .dsp_installed
.dsp_not_installed:
    bl _puts, fw_display_unavailable
.dsp_installed:

    bl _mc_get_mem_size
    mov r1, rr
    sub r0, r1, __emex64_exec_img_end
    
    bl _puts, fw_memory_msg
    bl _put_mem, r1, r1
    bl _putc, '\n'

    bl _puts, fw_memory_available_msg
    bl _put_mem, r0, r1
    bl _putc, '\n'
    
    bl _print_time
    bl _puts, fw_panic_msg

    ; intentionally causing a panic
    div r0, 0, 0
    
.hang:
    hlt
    b .hang

; main setup routine
_start:
    bl _put_init                                    ; checks for fb
    bl _pmm_init                                    ; initilizing page allocator
    bl _slab_init                                   ; initilizing slab allocator
    bl _interrupt_init                              ; initilizing interrupt controller
    bl _fw_start                                    ; branching to main symbol
.poweroff:
    stb PLATFORM_PWR, 0                             ; telling platform device to turn off
    
