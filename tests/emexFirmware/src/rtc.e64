%include% <emex64.e64inc>

section .data
    time db "[fw] date: \0"

_rtc_2putbase:
    cmp r0, 10
    bge .end
    blw _putc, '0'
.end:
    blw _putbase, r0, 10
    wret

_print_time:
    mov r1, RTC_DAY
    blw _puts, time
.loop:
    ldd r0, r1
    blw _rtc_2putbase, r0
    add r1, 4
    cmp r1, RTC_YEAR
    bgt .loop_2_entry
    blw _putc, '.'
    b .loop
.loop_2_entry:
    sub r1, 16
    blw _putc, ' '
.loop_2:
    ldd r0, r1
    blw _rtc_2putbase, r0
    sub r1, 4
    cmp r1, RTC_SECONDS
    blt .end
    blw _putc, ':'
    b .loop_2
.end:
    blw _putc, '\n'
    wret
