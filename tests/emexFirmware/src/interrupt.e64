%include% <emex64.e64inc>

section .bss
    ivec dq 63

_interrupt_init:
    ; allocate kernel stack for the interrupt handlers
    blw _pmm_alloc
    add rr, 0x1FFE
    mov cr1, rr

    ; setting up vector table onto interrupt controller
    stq INTC_REG_VECTOR, ivec
    stb INTC_REG_ENABLED, 0x0
    stq INTC_REG_CTRL, 1
    wret

_interrupt_register_handler:
    ; calculate interrupt vector handler slot address
    mul r3, r0, 8
    add r2, ivec, r3

    ; insert into vector table
    stq r2, r1

    ; now calculate bit and or it
    ldq r2, INTC_REG_ENABLED
    shl r1, 0x1, r0
    or r2, r1
    stq INTC_REG_ENABLED, r2
    wret

_interrupt_unregister_handler:
    ; calculate interupt vector handler slot address
    mul r2, r0, 8
    add r1, ivec, r2

    ; remove handler from vector table
    stq r2, 0x0

    ; now calculate bit and or it
    ldq r2, INTC_REG_ENABLED
    shl r1, 0x1, r0
    not r1
    and r2, r1
    stq INTC_REG_ENABLED, r2
    wret
