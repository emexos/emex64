; normal ass data for the system
section .data
    putc_uart_logo db "\n         +++++++++++++\n        ++++++++++++++\n       +++++++++++++++\n      ++++++++++++++++\n     +++++      ++++++\n    +++++      ++++++ \n   +++++      ++++++  \n  +++++      ++++++   \n +++++      ++++++    \n+++++      ++++++     \n+++++      +++++      \n +++++      +++       \n  +++++      +        \n   +++++              \n    +++++             \n     +++++            \n      ++++++++++++++++\n       +++++++++++++++\n        ++++++++++++++\n         +++++++++++++\n\0"
    putc_copyright db "\nemexLabs(c) 2026\n\n\0"
    putc_sym dq _gui_putc

; memory units for _put_mem
section .data
    mem_unit_b db "B\0"
    mem_unit_kb db "KB\0"
    mem_unit_mb db "MB\0"
    mem_unit_gb db "GB\0"
    mem_unit_tb db "TB\0"
    mem_unit_ptrs dq mem_unit_b, mem_unit_kb, mem_unit_mb, mem_unit_gb, mem_unit_tb

_putc:
    ldq r1, putc_sym
    b r1

_put_init:
    ldb r0, FB_ENABLED
    bnz r0, .end_gui
.end_uart:
    stq putc_sym, _uart_putc
    blw _puts, putc_uart_logo
    blw _puts, putc_copyright
    wret
.end_gui:
    stw gui_line, 10
    blw _puts, putc_copyright
    wret

_puts:
.start:
    ldb r1, r0
    inc r0
    blw _putc, r1
    bnz r1, .start
    wret
    
_putbase:
    clr rr
    bnz r0, .start
    blw _putc, '0'
    wret
.start:
    push 0
.loop:
    div r2, r0, r1
    mul r4, r2, r1
    sub r0, r4
    cmp r0, 10
    blt .digit
    add r0, 39
.digit:
    add r0, 48
.push:
    inc rr
    push r0
    mov r0, r2
    bnz r0, .loop
.print:
    pop r0
    blw _putc
    bnz r0, .print
    wret

;
; r0: main memory amount
; r1: amount to match the units to
;
_put_mem:
    push r0
    push r1
    clr r2
    pop r3
    bz r3, .auto
    mov r0, r3

.auto:
    cmp r0, 1024
    blt .unit_ok
    cmp r2, 4
    bge .unit_ok
    div r0, 1024
    inc r2
    b .auto
    
.unit_ok:
    pop r0
    mov r4, r0
    mov r3, r2
.whole_loop:
    bz r3, .whole_done
    div r0, 1024
    dec r3
    b .whole_loop

.whole_done:
    blw _putbase, r0, 10

    bz r2, .suffix

    blw _putc, '.'
    mov r3, r2
    mov r5, 1
.unit_sz:
    bz r3, .have_sz
    mul r5, 1024
    dec r3
    b .unit_sz

.have_sz:
    mod r4, r4, r5
    mul r6, r4, 10
    div r6, r5
    blw _putbase, r6, 10

.suffix:
    mul r2, 8
    add r2, mem_unit_ptrs
    ldq r0, r2
    blw _puts, r0
    blw _putc, ' '
    wret
